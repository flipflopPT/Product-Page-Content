{
  "name": "pt-pdp-content",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "import-content": "npx tsx scripts/import-content.ts",
    "cleanup-seasonal": "npx tsx --env-file .env.local scripts/cleanup-seasonal-override.ts",
    "cleanup-seasonal-booleans": "npx tsx --env-file .env.local scripts/cleanup-seasonal-booleans.ts",
    "migrate-icons": "npx tsx --env-file .env.local scripts/migrate-icon-names.ts",
    "migrate-metafield-keys": "npx tsx --env-file .env.local scripts/migrate-metafield-keys.ts",
    "clear-product-summaries": "npx tsx --env-file .env.local scripts/clear-product-summaries.ts",
    "clear-wct": "npx tsx --env-file .env.local scripts/clear-wct-content.ts",
    "clear-pf": "npx tsx --env-file .env.local scripts/clear-pf-content.ts",
    "approve-complete": "npx tsx --env-file .env.local scripts/approve-complete-products.ts",
    "migrate-library": "node scripts/migrate-library-to-metaobject.mjs",
    "migrate-library:dry-run": "node scripts/migrate-library-to-metaobject.mjs --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@shopify/app-bridge": "^3.7.11",
    "dompurify": "^3.4.9",
    "jose": "^6.2.2",
    "jsdom": "^29.1.1",
    "next": "16.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
